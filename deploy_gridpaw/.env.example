# GridPaw 多租户服务部署配置
# 复制本文件为 .env 并根据环境修改配置。

# Nginx 对外端口（唯一对用户暴露的端口）
NGINX_PORT=8087

# 创建租户容器时,为其命名的前缀,用于区分不同租户
INSTANCE_PREFIX=gridpaw-instance-

# 创建租户的GridPaw容器时使用的镜像名
TENANT_IMAGE=gridpaw-tenant:latest

# GridPaw 数据根目录（宿主机路径）
# 子目录结构由系统自动管理：
#   {GRIDPAW_DATA}/admin_data    — Admin 数据库和参考模板
#   {GRIDPAW_DATA}/tenants_data  — 各租户的 GridPaw 数据（每租户一个子目录）
#   {GRIDPAW_DATA}/shared_files  — 共享文件服务存储
# 快速测试可直接使用仓库内目录: GRIDPAW_DATA=./gridpaw_data
GRIDPAW_DATA=/home/root/var/gridpaw

# 共享文件服务对外访问地址,应该填写服务的对外IP地址,而不是127.0.0.1
# 如果填写127.0.0.1, 则租户GridPaw容器里的智能体无法通过127.0.0.1访问共享文件服务,因为租户容器不是以host模式运行的.
# 如果填写服务器的对外IP,则所有能访问到该IP的设备都可以访问共享文件服务.
FILE_SERVICE_BASE_URL=http://192.168.31.160
