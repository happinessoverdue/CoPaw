# Python cache
__pycache__/

.DS_Store

# Environment config (contains secrets)
.env

# gridpaw_data 已纳入 Git 跟踪，作为完整部署模板随仓库分发

# Shared file service storage (default volume)
shared_files/

# Exported images（目录结构保留，仅忽略导出的镜像文件）
images/*.tar
images/*.tar.gz
images/**/*.tar
images/**/*.tar.gz

# gridpaw_data 下所有内容均纳入 Git
!gridpaw_data/**
gridpaw_data/**/.DS_Store
# tenant_template 不纳入跟踪（含敏感配置、运行时生成内容等）
gridpaw_data/admin_data/tenant_template/
# tenants_data 仅保留目录占位，不跟踪其下文件
gridpaw_data/tenants_data/*

# vibe coding（AI 工具相关，均不跟踪）
.claude
.cursor
.cursorignore
openspec
# AGENTS.md # 模板AGENTS.md纳入跟踪
CLAUDE.md
*.tmp
