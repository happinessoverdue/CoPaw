# CoPaw Multi-Tenant Deployment Configuration
# Copy this file to .env and edit values for your environment.
# This file is auto-loaded by docker compose.

# Nginx external port (the only port exposed to users)
NGINX_PORT=80

# Cookie signing secret — CHANGE THIS to a random string in production
COOKIE_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# GridPaw instance Docker image name
COPAW_IMAGE=gridpaw-tenant:latest

# Host directory for per-user CoPaw data (each user gets a subdirectory)
BASE_DATA_DIR=/data/copaw

# Internal port CoPaw listens on inside each container (default 8088; must match nginx proxy target)
COPAW_INTERNAL_PORT=8088

# Admin panel password (username is always "admin")
ADMIN_PASSWORD=admin

# Template directory name under data/ (default: templates) — deploy_tenant/data/templates
TEMPLATES_DIR=templates

# 共享文件服务配置
FILE_SERVICE_BASE_URL=http://127.0.0.1   # 端口自动从 NGINX_PORT 补充
SHARED_FILES_DIR=./shared_files         # 宿主机存储路径
